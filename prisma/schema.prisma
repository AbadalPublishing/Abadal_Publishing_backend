// ────────────────────────────────────────────────────────────
// Abadal Publishing — Full Database Schema
// PostgreSQL · Prisma · UUIDs · Soft-deletes · Indexed
// ────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─────────── ENUMS ───────────

enum Role {
  SUPER_ADMIN
  AUTHOR
  CUSTOMER
}

enum ProductType {
  BOOK
  EBOOK
  MAGAZINE
  COURSE
}

enum VariantType {
  PAPERBACK
  HARDCOVER
  EBOOK
}

enum PriceType {
  RETAIL
  WHOLESALE
  STUDENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
  FAILED
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum Courier {
  TRAX
  LEOPARDS
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum AccountType {
  BANK
  JAZZCASH
  EASYPAISA
  NAYAPAY
  SADAPAY
}

enum AnalyticsEventType {
  PAGE_VIEW
  BOOK_CLICK
  WHATSAPP_CLICK
  AMAZON_CLICK
  ADD_TO_CART
  CHECKOUT_STARTED
  CHECKOUT_ABANDONED
  ORDER_PLACED
}

enum ReturnReason {
  DAMAGED
  WRONG_ITEM
  CHANGED_MIND
  OTHER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum StockReason {
  SALE
  RESTOCK
  ADJUSTMENT
  RETURN
  CANCELLED
}

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
}

enum SubmissionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

// ─────────── IDENTITY & AUTH ───────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  firstName            String
  lastName             String
  phone                String?
  city                 String?
  dateOfBirth          DateTime?
  role                 Role      @default(CUSTOMER)
  isActive             Boolean   @default(true)
  emailVerified        Boolean   @default(false)
  emailVerificationToken      String?   @unique
  emailVerificationExpiresAt  DateTime?
  phoneVerified        Boolean   @default(false)
  totalLifetimeSpend   Decimal   @default(0) @db.Decimal(12, 2)
  lastLoginAt          DateTime?
  lastLoginIp          String?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  author               Author?
  orders               Order[]
  cartItems            CartItem[]
  reviews              Review[]
  addresses            Address[]
  wishlist             WishlistItem[]
  paymentAccounts      PaymentAccount[]
  couponUsages         CouponUsage[]
  emailLogs            EmailLog[]
  auditLogs            AuditLog[]
  analyticsEvents      AnalyticsEvent[]
  activeSessions       ActiveSession[]
  cancelledOrders      Order[]   @relation("OrderCancelledBy")

  @@index([email])
  @@index([role])
}

model Author {
  id                String    @id @default(uuid())
  userId            String    @unique
  slug              String    @unique
  penName           String
  bio               String?
  photo             String?
  website           String?
  socialLinks       Json?
  nationality       String?
  languages         String[]  @default([])
  royaltyPercentage Decimal   @default(10) @db.Decimal(5, 2)
  isVerified        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          Product[]
  payouts           RoyaltyPayout[]
  orderItems        OrderItem[]

  @@index([slug])
}

model Otp {
  id        String   @id @default(uuid())
  phone     String?
  email     String?
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([email])
}

// ─────────── CATALOG ───────────

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  parentId    String?
  createdAt   DateTime  @default(now())

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([slug])
}

model Product {
  id               String           @id @default(uuid())
  title            String
  slug             String           @unique
  type             ProductType
  language         String           @default("English")
  description      String           @db.Text
  authorBio        String?          @db.Text
  tableOfContents  Json?
  editorialNote    String?          @db.Text
  pullQuote        String?          @db.Text
  coverImage       String?
  images           String[]         @default([])
  ogTitle          String?
  ogDescription    String?
  ogImage          String?
  awards           Json?
  tags             String[]         @default([])
  isbn             String?
  publisher        String           @default("Abadal Publishing")
  publishedDate    String?
  pages            Int?
  isFeatured       Boolean          @default(false)
  featuredUntil    DateTime?
  isActive         Boolean          @default(true)
  amazonUrl        String?
  whatsappEnabled  Boolean          @default(true)
  submissionStatus SubmissionStatus @default(APPROVED)
  submissionNote   String?
  authorId         String?
  categoryId       String?
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  author          Author?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants        ProductVariant[]
  reviews         Review[]
  wishlistItems   WishlistItem[]
  orderItems      OrderItem[]
  analyticsEvents AnalyticsEvent[]

  @@index([slug])
  @@index([categoryId])
  @@index([authorId])
  @@index([isFeatured])
  @@index([isActive])
  @@index([submissionStatus])
}

model ProductVariant {
  id                 String      @id @default(uuid())
  productId          String
  type               VariantType
  isbn               String?
  sku                String?
  retailPrice        Decimal     @db.Decimal(10, 2)
  wholesalePrice     Decimal     @db.Decimal(10, 2)
  studentPrice       Decimal     @db.Decimal(10, 2)
  listPrice          Decimal?    @db.Decimal(10, 2)
  stock              Int         @default(0)
  lowStockThreshold  Int         @default(10)
  weight             Decimal?    @db.Decimal(8, 2)
  length             Decimal?    @db.Decimal(6, 2)
  width              Decimal?    @db.Decimal(6, 2)
  height             Decimal?    @db.Decimal(6, 2)
  royaltyPercentage  Decimal     @default(10) @db.Decimal(5, 2)
  amazonOnly         Boolean     @default(false)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  product            Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems          CartItem[]
  orderItems         OrderItem[]
  stockMovements    StockMovement[]

  @@index([productId])
}

model StockMovement {
  id         String      @id @default(uuid())
  variantId  String
  delta      Int
  reason     StockReason
  orderId    String?
  adminId    String?
  createdAt  DateTime    @default(now())

  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
}

// ─────────── SHOPPING ───────────

model Address {
  id           String   @id @default(uuid())
  userId       String
  label        String   @default("Home")
  firstName    String
  lastName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String?
  postalCode   String?
  country      String   @default("Pakistan")
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
}

model CartItem {
  id         String     @id @default(uuid())
  userId     String
  variantId  String
  quantity   Int        @default(1)
  priceType  PriceType  @default(RETAIL)
  savedPrice Decimal    @db.Decimal(10, 2)
  addedAt    DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  addedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Coupon {
  id              String       @id @default(uuid())
  code            String       @unique
  type            CouponType
  value           Decimal      @db.Decimal(10, 2)
  maxUses         Int?
  usedCount       Int          @default(0)
  onePerCustomer  Boolean      @default(true)
  validFrom       DateTime
  validUntil      DateTime
  minOrderValue   Decimal?     @db.Decimal(10, 2)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  usages          CouponUsage[]

  @@index([code])
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  orderId   String
  usedAt    DateTime @default(now())

  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────── ORDERS ───────────

model Order {
  id                  String         @id @default(uuid())
  orderNumber         String         @unique
  userId              String
  addressId           String
  status              OrderStatus    @default(PENDING)
  paymentMethod       PaymentMethod
  subtotal            Decimal        @db.Decimal(12, 2)
  shippingCost        Decimal        @default(0) @db.Decimal(10, 2)
  discountAmount      Decimal        @default(0) @db.Decimal(10, 2)
  couponCode          String?
  couponDiscount      Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount         Decimal        @db.Decimal(12, 2)
  authorRoyaltyAmount Decimal        @default(0) @db.Decimal(12, 2)
  courier             Courier?
  notes               String?
  cancelledAt         DateTime?
  cancelledById       String?
  deliveredAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  cancelledBy         User?          @relation("OrderCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  address             Address        @relation(fields: [addressId], references: [id], onDelete: Restrict)
  items               OrderItem[]
  payments            Payment[]
  shipment            Shipment?
  couponUsages        CouponUsage[]
  return              Return?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([orderNumber])
  @@index([userId, status])
  @@index([status, createdAt])
}

model OrderItem {
  id          String       @id @default(uuid())
  orderId     String
  productId   String
  variantId   String
  authorId    String?
  // Snapshot fields (preserved at order time)
  title       String
  coverImage  String?
  variantType VariantType
  priceType   PriceType
  pricePaid   Decimal      @db.Decimal(10, 2)
  quantity    Int
  total       Decimal      @db.Decimal(12, 2)
  royaltyPct  Decimal      @db.Decimal(5, 2)

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  author      Author?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Payment {
  id                 String        @id @default(uuid())
  orderId            String
  method             PaymentMethod
  amount             Decimal       @db.Decimal(12, 2)
  status             PaymentStatus
  gatewayRef         String?
  gatewayResponse    Json?
  gatewayTimestamp   DateTime?
  customerPhone      String?
  createdAt          DateTime      @default(now())

  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Return {
  id           String       @id @default(uuid())
  orderId      String       @unique
  userId       String
  reason       ReturnReason
  description  String?
  status       ReturnStatus @default(REQUESTED)
  refundAmount Decimal?     @db.Decimal(12, 2)
  refundMethod PaymentMethod?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─────────── SHIPPING ───────────

model Shipment {
  id                 String   @id @default(uuid())
  orderId            String   @unique
  courier            Courier
  trackingNumber     String?
  bookingId          String?
  status             String   @default("pending")
  statusHistory      Json?
  rawResponse        Json?
  estimatedDelivery  DateTime?
  actualDelivery     DateTime?
  shippingCost       Decimal? @db.Decimal(10, 2)
  weight             Decimal? @db.Decimal(8, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([trackingNumber])
  @@index([orderId])
  @@index([courier])
}

// ─────────── REVIEWS ───────────

model Review {
  id            String       @id @default(uuid())
  userId        String
  productId     String
  orderId       String?
  rating        Int
  title         String?
  body          String?      @db.Text
  status        ReviewStatus @default(PENDING)
  helpfulCount  Int          @default(0)
  adminNote     String?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([status])
}

// ─────────── PAYMENT ACCOUNTS ───────────

model PaymentAccount {
  id                String       @id @default(uuid())
  ownerId           String       // Super Admin or Author
  type              AccountType
  accountTitle      String
  accountNumber     String       // IBAN or wallet phone
  bankName          String?
  isDefault         Boolean      @default(false)
  isCustomerFacing  Boolean      @default(false) // Admin-only field; for authors always false
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  owner             User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, type])
  @@index([ownerId])
}

model RoyaltyPayout {
  id        String   @id @default(uuid())
  authorId  String
  amount    Decimal  @db.Decimal(12, 2)
  period    String   // e.g. "2026-04"
  paidAt    DateTime?
  bankRef   String?
  status    String   @default("PENDING") // PENDING | PAID | FAILED
  notes     String?
  createdAt DateTime @default(now())

  author    Author   @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([authorId])
  @@index([period])
}

// ─────────── ANALYTICS ───────────

model AnalyticsEvent {
  id         String              @id @default(uuid())
  eventType  AnalyticsEventType
  sessionId  String
  userId     String?
  productId  String?
  pageUrl    String?
  referrer   String?
  city       String?
  country    String?
  deviceType DeviceType?
  metadata   Json?
  createdAt  DateTime            @default(now())

  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  product    Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([sessionId])
  @@index([productId])
  @@index([createdAt])
}

model DailyStats {
  id              String   @id @default(uuid())
  date            DateTime @unique
  totalVisitors   Int      @default(0)
  uniqueVisitors  Int      @default(0)
  totalOrders     Int      @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  topProductId    String?
  newUsers        Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([date])
}

model ActiveSession {
  sessionId   String      @id
  userId      String?
  lastSeen    DateTime    @default(now())
  city        String?
  country     String?
  deviceType  DeviceType?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSeen])
}

// ─────────── SETTINGS & SYSTEM ───────────

model SiteSettings {
  id                  String   @id @default(uuid())
  storeName           String   @default("Abadal Publishing")
  storeEmail          String   @default("info@abadalpublishing.com")
  storePhone          String?
  whatsappNumber      String   @default("923039555966")
  address             String?
  city                String   @default("Peshawar")
  country             String   @default("Pakistan")
  socialLinks         Json?
  shippingRate        Decimal  @default(200) @db.Decimal(10, 2)
  freeShippingAbove   Decimal  @default(2000) @db.Decimal(10, 2)
  lowStockThreshold   Int      @default(10)
  amazonAffiliateUrl  String?
  updatedAt           DateTime @updatedAt
}

// WhatsApp guest orders — self-contained, no FKs.
// Saved when a customer completes the in-app journey and clicks "Send to WhatsApp".
model WhatsappOrder {
  id          String   @id @default(uuid())
  refCode     String   @unique  // e.g. ABDL-7K2X
  // Customer
  name        String
  phone       String
  email       String?
  // Address
  street      String
  city        String
  country     String   @default("Pakistan")
  notes       String?
  // Book / pricing snapshot (paperback-only for now)
  productId   String?
  bookTitle   String
  edition     String   @default("Paperback")
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(12, 2)
  shipping    Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING)
  // Approval / payment confirmation (set when admin approves)
  paymentAccount      String?   // free text — e.g. "JazzCash 03001234567"
  paymentReceivedAt   DateTime?
  approvedAt          DateTime?
  // Delivery confirmation (set when customer scans QR + confirms)
  deliveredAt         DateTime?
  deliveryConfirmedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([refCode])
}

model AuditLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  ip          String?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([adminId])
  @@index([entityType])
  @@index([createdAt])
}

model EmailLog {
  id        String   @id @default(uuid())
  userId    String?
  type      String
  subject   String
  toEmail   String
  status    String
  sentAt    DateTime @default(now())
  error     String?

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
}
